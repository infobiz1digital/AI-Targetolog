# =============================================================================
# Environment variables for the Railway deployment
# Copy this to .env locally OR paste each value into Railway → Variables UI.
# NEVER commit a real .env file — it's in .gitignore.
# =============================================================================

# ---------- Meta / Facebook Ads API ----------
# System User token (permanent — get from Business Manager → System Users → Generate token)
# Scopes needed: ads_management, ads_read, business_management, pages_read_engagement
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ---------- Claude Code authentication ----------
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- code-server (VS Code in browser) ----------
# Password you'll type when opening the Railway URL in browser
CODE_SERVER_PASSWORD=

# ---------- GitHub (so the agent can pull configs + push commits back) ----------
# Personal Access Token (fine-grained) with read+write on the AI-Targetolog repo
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/infobiz1digital/AI-Targetolog.git
GITHUB_BRANCH=main

# Author identity used for commits Claude makes from inside the container
GIT_USER_NAME=AI Ads Agent
GIT_USER_EMAIL=agent@infobiz1digital.local

# ---------- Optional ----------
# Railway sets $PORT automatically; defaults to 8080 if absent
# PORT=8080
